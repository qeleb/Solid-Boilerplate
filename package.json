{
  "name": "solid-boilerplate",
  "version": "0.1.0",
  "description": "Solid Boilerplate",
  "author": "qeleb",
  "license": "UNLICENSED",
  "type": "module",
  "engines": {
    "node": ">=24.x"
  },
  "browserslist": {
    "production": [
      "chrome >=109",
      "firefox >=121",
      "safari >=16.4",
      "ios_saf >=16.4"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "lint-staged": {
    "*.{html,json,yaml}": "prettier --write --list-different --cache --cache-location=node_modules/.cache/prettier/.prettier-cache",
    "*.{js,jsx,ts,tsx,cjs,mjs,cts,mts}": "eslint --fix",
    "*.{css,scss,sass}": [
      "stylelint --fix --cache --cache-location=node_modules/.cache/stylelint/",
      "prettier --write --list-different --cache --cache-location=node_modules/.cache/prettier/.prettier-cache"
    ]
  },
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "build": "vite build",
    "build:analyze": "ANALYZE=true && vite build",
    "test": "vitest run --coverage",
    "test:ui": "vitest run --coverage --ui",
    "lint-code": "eslint src",
    "lint-styles": "stylelint src/**/*.scss --cache --cache-location=node_modules/.cache/stylelint/",
    "lint": "eslint src && stylelint src/**/*.scss --cache --cache-location=node_modules/.cache/stylelint/",
    "lint:fix": "eslint --fix src && stylelint --fix src/**/*.scss --cache --cache-location=node_modules/.cache/stylelint/",
    "preinstall": "npx only-allow yarn",
    "postinstall": "husky"
  },
  "devDependencies": {
    "@babel/plugin-transform-typescript": "^7.29.7",
    "@solidjs/testing-library": "^0.8.10",
    "@swc/core": "^1.15.46",
    "@swc/html": "^1.15.46",
    "@testing-library/jest-dom": "^7.0.0",
    "@types/node": "^24.13.3",
    "@vitest/coverage-v8": "^3.2.7",
    "@vitest/eslint-plugin": "1.6.23",
    "@vitest/ui": "^3.2.7",
    "babel-plugin-react-remove-properties": "^0.3.1",
    "browserslist-to-esbuild": "^2.1.1",
    "eslint": "^9.39.5",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.17.1",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-regexp": "^3.1.1",
    "eslint-plugin-solid": "^0.14.5",
    "eslint-plugin-testing-library": "^7.16.2",
    "eslint-plugin-unicorn": "^65.0.1",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lightningcss": "~1.30.2",
    "lint-staged": "^17.1.1",
    "miragejs": "^0.1.48",
    "postcss": "^8.5.22",
    "postcss-sort-media-queries": "^6.6.2",
    "prettier": "^3.9.6",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.100.0",
    "stylelint": "^17.14.1",
    "stylelint-config-hudochenkov": "^13.0.2",
    "stylelint-config-recommended-scss": "^17.0.1",
    "stylelint-no-unsupported-browser-features": "^8.1.1",
    "stylelint-order": "^8.1.1",
    "terser": "^5.49.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.65.0",
    "vite": "^7.3.6",
    "vite-css-modules": "^1.16.0",
    "vite-plugin-checker": "^0.14.5",
    "vite-plugin-optimize-css-modules": "^1.4.0",
    "vite-plugin-solid": "^2.11.13",
    "vite-plugin-svgo": "^2.0.0",
    "vitest": "^3.2.7"
  },
  "dependencies": {
    "@solidjs/router": "0.10.1",
    "solid-js": "1.8.5",
    "solidjs-use": "^2.3.0"
  },
  "resolutions": {
    "@babel/helper-module-imports": "^7.29.7",
    "aria-query@npm:5.3.0": "^5.3.2",
    "babel-plugin-jsx-dom-expressions": "^0.39.8",
    "known-css-properties": "^0.37.0",
    "mdn-data": "latest",
    "svgo": "^4.0.1"
  },
  "packageManager": "yarn@4.17.0"
}
