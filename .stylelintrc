{
  "extends": ["stylelint-config-recommended-scss", "stylelint-config-hudochenkov/order"],
  "plugins": ["stylelint-no-unsupported-browser-features"],
  "defaultSeverity": "warning",
  "ignoreFiles": ["node_modules/**", "dist/**", "coverage/**"],
  "rules": {
    "at-rule-empty-line-before": [
      "always",
      { "except": ["blockless-after-same-name-blockless", "first-nested"], "ignore": ["after-comment"] }
    ],
    "at-rule-no-vendor-prefix": true,
    "color-function-notation": "modern",
    "color-hex-length": "short",
    "comment-whitespace-inside": "always",
    "declaration-block-no-redundant-longhand-properties": true,
    "declaration-property-value-disallowed-list": [
      { "/^overflow(-(x|y|inline|block))?$/i": ["/\\bscroll\\b/i"] },
      {
        "message": "Use auto or hidden instead of scroll to avoid issues. https://blog.kizu.dev/never-use-overflow-scroll"
      }
    ],
    "font-family-name-quotes": "always-where-recommended",
    "function-name-case": "lower",
    "function-url-quotes": "always",
    "hue-degree-notation": "angle",
    "import-notation": "url",
    "keyframe-selector-notation": "percentage-unless-within-keyword-only-block",
    "length-zero-no-unit": [true, { "ignore": ["custom-properties"] }],
    "media-feature-range-notation": "context",
    "no-descending-specificity": null,
    "no-duplicate-selectors": true,
    "no-invalid-position-declaration": [true, { "severity": "error" }],
    "property-disallowed-list": [
      "flex-direction",
      "/^-moz-animation(?:-delay|-direction|-duration|-fill-mode|-iteration-count|-name|-play-state|-timing-function)?$/",
      "-moz-appearance",
      "-moz-backface-visibility",
      "/^-moz-background-(?:clip|inline-policy|origin|size)$/",
      "/^-moz-border-(?:end|end-color|end-style|end-width|image|start|start-color|start-style|start-width)$/",
      "/^-moz-box-(?:align|direction|flex|ordinal-group|orient|pack|sizing)$/",
      "/^-moz-column-(?:count|fill|gap|rule|rule-color|rule-style|rule-width|width)$/",
      "/^-moz-font-(?:feature-settings|language-override)$/",
      "-moz-hyphens",
      "/^-moz-margin-(?:end|start)$/",
      "-moz-opacity",
      "/^-moz-outline(?:-color|-offset|-style|-width)?$/",
      "/^-moz-padding-(?:end|start)$/",
      "/^-moz-perspective(?:-origin)?$/",
      "-moz-tab-size",
      "/^-moz-text-(?:align-decoration-color|decoration-line|decoration-style)$/",
      "/^-moz-transform(?:-origin|-style)?$/",
      "/^-moz-transition(?:-delay|-duration|-property|-timing-function)?$/",
      "-moz-user-select",
      "/^-webkit-border-(?:after|before|end|start)$/",
      "/^-webkit-box-(?!reflect)/",
      "/^-webkit-column-break-(?:after|before|inside)$/",
      "-webkit-font-feature-settings",
      "/^-webkit-margin-(?:end|start)$/",
      "/^-webkit-padding-(?:after|before|end|start)$/"
    ],
    "property-no-deprecated": [true, { "ignoreProperties": ["word-wrap"] }],
    "property-no-unknown": [true, { "ignoreProperties": ["composes"] }],
    "rule-empty-line-before": ["always-multi-line", { "except": ["first-nested"], "ignore": ["after-comment"] }],
    "selector-attribute-quotes": "always",
    "selector-no-vendor-prefix": true,
    "selector-not-notation": "complex",
    "selector-pseudo-class-no-unknown": [true, { "ignorePseudoClasses": ["local", "global"] }],
    "selector-pseudo-element-colon-notation": "double",
    "selector-type-case": "lower",
    "shorthand-property-no-redundant-values": true,
    "value-keyword-case": "lower",
    "value-no-vendor-prefix": true,
    "scss/no-unused-private-members": true,
    "plugin/no-unsupported-browser-features": [
      true,
      { "ignorePartialSupport": true, "ignore": ["css-nesting", "css-media-range-syntax"] }
    ]
  }
}
